VITE_API_BASE_URL=https://api.vp.lcsl.fr/v1
# VITE_API_BASE_URL=http://localhost:3000/v1

# Nom commercial affiché dans toute l'application (header, titres, manifest PWA,
# notifications système, e-mails liés au front).
