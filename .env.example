VITE_API_BASE_URL=http://localhost:3000/v1

# Nom commercial de l'application (utilisé partout dans l'UI, le titre HTML,
# le manifeste PWA et les notifications navigateur).
VITE_APP_NAME=MonAppli

# `false` (défaut) = phase de pré-lancement (landing + pré-inscriptions seulement).
# `true` = ouverture publique (login/register/app accessibles).
VITE_APP_OPEN=false
